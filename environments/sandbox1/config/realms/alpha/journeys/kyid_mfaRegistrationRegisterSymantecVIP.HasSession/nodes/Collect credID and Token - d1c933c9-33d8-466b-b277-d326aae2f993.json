  "pageDescription": {
    "en": "<div class='page-footer-horizontal'><br>\n<h5 style=\"color:#5e5e5e;\">Set up Symantec VIP</h5>\n<a href=\"&{esv.kog.help.mfa.reg.symantec.url}\"target=\"_blank\">Need Assistance?</a><br>\n<br>\n<h5 style=\"color:#5e5e5e;\">If you do not have Symantec VIP app then download and install the app on your desktop or mobile by visiting <a href=\"https://vip.symantec.com/\">https://vip.symantec.com</a>\n<br>\nFrom the Symantec VIP app, enter your credential ID and two consecutive generated codes.</h5>",
    "es": "<div class='page-footer-horizontal'><br>\n<h5 style=\"color:#5e5e5e;\">Configurar Symantec VIP</h5>\n<a href=\"&{esv.kog.help.mfa.reg.symantec.url}\"target=\"_blank\">¿Necesita ayuda?</a><br>\n<br>\n<h5 style=\"color:#5e5e5e;\">Si no tiene la aplicación Symantec VIP, descárguela e instálela en su computadora de escritorio o dispositivo móvil visitando <a href=\"https://vip.symantec.com/\">https://vip.symantec.com</a>\n<br>\nDesde la aplicación Symantec VIP, ingrese su ID de credencial y dos códigos generados consecutivos.</h5>"
  },
