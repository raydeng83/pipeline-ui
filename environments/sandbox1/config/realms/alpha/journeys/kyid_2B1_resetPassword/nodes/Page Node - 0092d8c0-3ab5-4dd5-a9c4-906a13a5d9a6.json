    "en": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title text-align-left\">\n<h5>Create a new password</h5></div>\n<div>\n\n<div class=\" page-header-content text-align-left\">\n<div class=\"page-header-title\"><h5>Password Requirements</h5></div>\n<ul lass=\"text-align-left\">\n<li>At least 8 characters</li>\n<li>A lowercase letter</li>\n<li>An uppercase letter</li>\n<li>A number</li>\n<li>Does not include your first name</li>\n<li>Does not include your last name</li>\n<li>Password can't be the same as your last 24 passwords</li>\n</ul>\n</div>",
