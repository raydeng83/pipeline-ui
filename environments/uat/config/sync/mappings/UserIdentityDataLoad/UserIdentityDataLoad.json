        "source": "logger.info(\"Source user identity: \" + JSON.stringify(source));\nvar sourceKyid = source.KYID;\nvar resultArray = [];\ntry {\n\tif(!sourceKyid == null || !sourceKyid == \"\"){\n\t\tvar uniqueKyids = Array.from(new Set(sourceKyid.split(\",\").map(function(item) { return item.trim(); })));\n\t\t// Process each unique role\n\t\tuniqueKyids.forEach(function(kyid) {\n\t\t\t\tvar identityRef = { \"_ref\": \"managed/alpha_user/\" + kyid };\n\t\t\t\tresultArray.push(identityRef);\n\t\t});\n\t}else{\n\t\tnull;\n\t\t}\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);\n}\nresultArray;",
