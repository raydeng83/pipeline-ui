        "globals": {},
        "source": "logger.error(\"Source user identity: \" + JSON.stringify(source));\n\nvar sourceKyid = source._id;\nvar resultArray = [];\n \ntry {\n    \n\tif(!sourceKyid == null || !sourceKyid == \"\"){\n\t\tvar uniqueKyids = Array.from(new Set(sourceKyid.split(\",\").map(function(item) { return item.trim(); })));\n\t\tlogger.error(\"Unique user identities: \" + JSON.stringify(uniqueKyids));\n\t\t// Process each unique role\n\t\tuniqueKyids.forEach(function(kyid) {\n\t\t\tlogger.error(\"kyid inside for loop: \"+kyid);\n\t\t\t//if (exclusionRoleResponse.result && exclusionRoleResponse.result.length > 0) {\n\t\t\t\t//var roleId = exclusionRoleResponse.result[0]._id;\n\t\t\t\tvar identityRef = { \"_ref\": \"managed/alpha_user/\" + kyid };\n\t\t\t\tresultArray.push(identityRef);\n\t\t\t//}\n\t\t});\n\t\tlogger.error(\"Result Array: \" + JSON.stringify(resultArray));\n\t}else{\n\t\tlogger.error(\"inside else\");\n\t\tnull;\n\t\t}\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);\n}\n \nresultArray;",
        "type": "text/javascript"
      }
