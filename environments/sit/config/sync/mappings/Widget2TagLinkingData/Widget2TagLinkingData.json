      "type": "text/javascript"
    }
  ],
  "displayName": "Widget2TagLinkingData",
  "enableSync": false,
  "name": "Widget2TagLinkingData",
  "policies": [
    {
      "action": "ASYNC",
      "situation": "AMBIGUOUS"
    },
    {
      "action": "ASYNC",
