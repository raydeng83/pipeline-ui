  "properties": [
    {
      "source": "__NAME__",
      "target": "widgentIdentifier"
    },
    {
      "source": "",
      "target": "widgetTags",
      "transform": {
        "globals": {},
        "source": "logger.info(\"Source tag names: \" + JSON.stringify(source));\nvar sourceTagName = source.TagName;\nvar resultArray = [];\n try {\n    var uniquesourceTagNames = Array.from(new Set(sourceTagName.split(\"|\").map(function(item) { return item.trim(); })));\n    uniquesourceTagNames.forEach(function(tagName) {\n        var tagNameResponse = openidm.query(\n            \"managed/alpha_kyid_tag\",\n            {\n                \"_queryFilter\": 'name eq \"' + tagName + '\"'\n            },\n            [\"_id\"]\n        );\n        if (tagNameResponse.result && tagNameResponse.result.length > 0) {\n            var tagId = tagNameResponse.result[0]._id;\n            var tagRef = { \"_ref\": \"managed/alpha_kyid_tag/\" + tagId };\n            resultArray.push(tagRef);\n        }\n    });\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);\n}\nresultArray;",
        "type": "text/javascript"
      }
    }
  ],
  "reconSourceQueryPageSize": {
    "$int": "&{esv.dbconnector.querypagesize}"
  },
  "reconSourceQueryPaging": true,
  "runTargetPhase": false,
  "source": "system/DBConnector_ApplicationWidgetTagAssocStaging/__ACCOUNT__",
  "sourceQuery": {
    "_queryFilter": "ReconFlag eq \"yes\"",
    "_sortKeys": "ReconFlag"
  },
  "sourceQueryFullEntry": true,
  "target": "managed/alpha_kyid_dashboardapplicationwidget",
  "taskThreads": {
    "$int": "&{esv.dbconnector.taskthreads}"
  }
}