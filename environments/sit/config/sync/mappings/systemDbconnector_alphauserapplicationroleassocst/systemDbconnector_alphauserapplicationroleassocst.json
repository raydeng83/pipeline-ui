    {
      "source": "",
      "target": "roles",
      "transform": {
        "globals": {},
        "source": "logger.info(\"Source: \" + JSON.stringify(source));\nvar roleIds = source.RoleIdentifier;\nvar resultArray = [];\ntry {\n    var uniqueRoles = Array.from(new Set(roleIds.split(\",\").map(function (item) { return item.trim(); })));\n    uniqueRoles.forEach(function (roleId) {\n        resultArray.push({ \"_ref\": \"managed/alpha_role/\" + roleId });\n    });\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);\n}\nresultArray;",
        "type": "text/javascript"
      }
    }
