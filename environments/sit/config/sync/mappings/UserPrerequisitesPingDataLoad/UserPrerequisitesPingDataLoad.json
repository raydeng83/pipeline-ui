        "globals": {},
        "source": "if(!source == null || !source == \"\"){\nvar sourcePrereqId = source._refResourceId;\ntry {\n\t\n    var prereqResponse = openidm.query(\n        \"managed/alpha_kyid_enrollment_prerequisite\",{\n             \"_queryFilter\": '_id eq \"' + sourcePrereqId + '\"'\n        },\n        [\"name\"]\n    );\n    if (prereqResponse.result && prereqResponse.result.length == 1) {\n\t\tvar prereqName = prereqResponse.result[0].name;\n    } else {\n\t\tlogger.error(\"Exception occurred during prereq to prereq type link \" );\n    }\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);  \n}\nprereqName;\n}else{\n\tnull;\n}",
