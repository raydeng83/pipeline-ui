  "pageDescription": {
    "en": "<div class='page-footer-horizontal'><br>\n<html>\n<head>\n</head>\n<body>\n    <left>\n<div>\n<p style=\"color:#5e5e5e;\nfont-weight\n: bold;\n\">Your password has expired</p></div>\n<div>\n<ul style=\"color:#6e6e78;text-align: left\">\n<h5>Password Requirements:</h5>\n<li>At least 8 characters</li>\n<li>A lowercase letter</li>\n<li>A uppercase letter</li>\n<li>A number</li>\n<li>Does not include your first name</li>\n<li>Does not include your last name</li>\n<li>Password can't be the same as your last 24 passwords</li>\n</ul>\n</div>\n</left>\n</body>\n</html>",
    "es": "<div class='page-footer-horizontal'><br>\n<html>\n<head>\n</head>\n<body>\n    <left>\n<div>\n<p style=\"color:#5e5e5e;\nfont-weight\n: bold;\n\">Tu contraseña ha caducado</p></div>\n<div>\n<ul style=\"color:#6e6e78;text-align: left\">\n<h5>Requisitos de contraseña:</h5>\n<li>Al menos 8 caracteres</li>\n<li>Una letra minúscula</li>\n<li>Una letra mayúscula</li>\n<li>Un número</li>\n<li>No incluye su nombre</li>\n<li>No incluye su apellido</li>\n<li>La contraseña no puede ser la misma que sus últimas 24 contraseñas</li>\n</ul>\n</div>\n</left>\n</body>\n</html>"
