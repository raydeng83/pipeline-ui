{
  "_id": "kyidHttpClient",
  "_type": {
    "_id": "instances",
    "collection": true,
    "name": "Http Client Instance Configuration"
  },
  "core": {
    "enabled": true
  },
  "proxy": {
    "useInstanceProxy": false
  },
  "timeouts": {
    "connectionTimeout": 10,
    "responseTimeout": 10,
    "useInstanceTimeouts": true
  },
  "tls": {
    "disableRevocationChecks": false,
    "mtlsClientCertSecretPurpose": "kyidCrt",
    "trustAllCertificates": false
  }
}