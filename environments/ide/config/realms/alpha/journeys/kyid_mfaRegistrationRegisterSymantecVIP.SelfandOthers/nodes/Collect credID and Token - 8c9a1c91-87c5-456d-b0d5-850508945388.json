  "pageDescription": {
    "en": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title\"><h5>Set up Symantec VIP</h5></div>\n<div class=\"page-element\">\n<a href=\"&{esv.kog.help.mfa.reg.symantec.url}\"target=\"_blank\">Need Assistance?</a>\n</div>\n<div class=\"page-header-content\">\nIf you do not have Symantec VIP app then download and install the app on your desktop or mobile by visiting <a href=\"https://vip.symantec.com/\">https://vip.symantec.com/</a>\n<br>\n<br>\nFrom the Symantec VIP app, enter your credential ID and two consecutive generated codes.\n</div>",
    "es": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title\"><h5>Configurar Symantec VIP</h5></div>\n<div class=\"page-element\">\n<a href=\"&{esv.kog.help.mfa.reg.symantec.url}\"target=\"_blank\">¿Necesita ayuda?</a>\n</div>\n<div class=\"page-header-content\">\nSi no tiene la aplicación Symantec VIP, descárguela e instálela en su computadora de escritorio o dispositivo móvil visitando <a href=\"https://vip.symantec.com/\">https://vip.symantec.com/</a>\n<br>\n<br>\nDesde la aplicación Symantec VIP, ingrese su ID de credencial y dos códigos generados consecutivos.\n</div>"
  },
