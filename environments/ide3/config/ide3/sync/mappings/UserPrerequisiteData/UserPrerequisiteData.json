        "source": "logger.info(\"Source object preerquisite: \" + JSON.stringify(source));\nvar prereqName = source.PrerequisiteName;\nvar result = {}; \ntry {\n    var prereqResponse = openidm.query(\n        \"managed/alpha_kyid_enrollment_prerequisite\",\n        {\n            \"_queryFilter\": 'name eq \"' + prereqName + '\"'\n        },\n        [\"_id\"]\n    );\n    if (prereqResponse.result && prereqResponse.result.length > 0) {\n\t\tvar prereqId = prereqResponse.result[0]._id;\n\t\tvar prereqRef = { \"_ref\": \"managed/alpha_kyid_enrollment_prerequisite/\" + prereqId };\n    } else {\n\t\tlogger.error(\"Exception occurred in else \" );\n\t\tnull;\n    }\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);  \n}\nprereqRef;",
