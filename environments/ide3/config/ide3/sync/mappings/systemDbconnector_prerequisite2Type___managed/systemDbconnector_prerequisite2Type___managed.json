      "source": "PreRequisiteSourceName",
      "target": "prerequisiteSourceName"
    },
    {
      "source": "",
      "target": "prereqTypeId",
      "transform": {
        "globals": {},
        "source": "logger.info(\"Source object: \" + JSON.stringify(source));\nvar prerequisiteId = source.PrerequisiteId;\nvar sourceName = source.PreRequisiteSourceName;\ntry {\n    var typeResponse = openidm.query(\n        \"managed/alpha_kyid_enrollment_prerequisite_type\",\n        {\n            \"_queryFilter\": 'prerequisiteId eq \"' + prerequisiteId + '\" and prerequisiteSourceName eq \"' + sourceName + '\"'\n        },\n        [\"_id\"]\n    ); \n    if (typeResponse.result && typeResponse.result.length > 0) {\n\t\tvar prereqId = typeResponse.result[0]._id;\n\t\tvar prereqRef = { \"_ref\": \"managed/alpha_kyid_enrollment_prerequisite_type/\" + prereqId };\n    } else {\n\t\tlogger.error(\"Exception occurred in else\" );\n\t\tnull;\n    }\n} catch (e) {\n    logger.error(\"Exception occurred: \" + e);  \n}\nprereqRef;",
        "type": "text/javascript"
      }
    }
  ],
  "reconSourceQueryPageSize": {
