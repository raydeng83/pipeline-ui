  "pageDescription": {
    "en": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title\"><h5>Set up phone authentication</h5></div>\n<div class=\"page-element\">\n<a href=\"&{esv.kog.help.mfa.reg.sms.url}\" target=\"_blank\">Need Assistance?</a>\n</div>\n<div class=\"page-header-content\">\nEnter your phone number to receive a verification code via SMS or Voice. Carrier messaging charges may apply.\n</div>",
    "es": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title\"><h5>Configurar la autenticación del teléfono</h5></div>\n<div class=\"page-element\">\n<a href=\"&{esv.kog.help.mfa.reg.sms.url}\" target=\"_blank\">¿Necesita\nayuda?</a>\n</div>\n<div class=\"page-header-content\">\nIngrese su número de teléfono para recibir un código de verificación vía SMS o voz. Se pueden aplicar cargos por mensajes del operador.\n</div>"
  },
