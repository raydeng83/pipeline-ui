  "pageDescription": {
    "en": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title text-align-left\">\n<h5>Reset your Kentucky Online Gateway password</h5></div>\n<div>\n\n<div class=\" page-header-content text-align-left\">\n<div class=\"page-header-title\"><h5>Password Requirements</h5></div>\n<ul lass=\"text-align-left\">\n<li>At least 8 characters</li>\n<li>A lowercase letter</li>\n<li>An uppercase letter</li>\n<li>A number</li>\n<li>Does not include your first name</li>\n<li>Does not include your last name</li>\n<li>Password can't be the same as your last 24 passwords</li>\n</ul>\n</div>",
    "es": "<div class='page-footer-horizontal'>\n<div class=\"page-header-title text-align-left\"><h5>\nRestablecer la contraseña de Kentucky Online Gateway</div>\n</h5><div>\n \n<div class=\" page-header-content text-align-left\">\n<div class=\"page-header-title\"><h5>Requisitos de contraseña</h5></div>\n<ul lass=\"text-align-left\">\n<li>Al menos 8 caracteres</li>\n<li>Una letra minúscula</li>\n<li>Una letra mayúscula</li>\n<li>Un número</li>\n<li>No incluye su nombre</li>\n<li>No incluye su apellido</li>\n<li>La contraseña no puede ser la misma que sus últimas 24 contraseñas</li>\n</ul>\n</div>"
  },
